def find_all_substrings(text):
    substrings = []
    length = len(text)
    
    # Double loop iteration generates every slice permutation
    for i in range(length):
        for j in range(i + 1, length + 1):
            substrings.append(text[i:j])
            
    return substrings

# Test execution
print("Substrings of 'cat':", find_all_substrings("cat"))
