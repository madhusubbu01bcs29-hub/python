text_input = "Programming"

# Slicing syntax: [start:stop:step]
even_positions = text_input[0::2]  # Index 0, 2, 4, ...
odd_positions = text_input[1::2]   # Index 1, 3, 5, ...

print(f"Original: {text_input}")
print(f"Even index positions: {even_positions}")
print(f"Odd index positions: {odd_positions}")
