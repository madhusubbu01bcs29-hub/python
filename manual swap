def manual_swapcase(text):
    swapped_chars = []
    for char in text:
        if char.isupper():
            swapped_chars.append(char.lower())
        elif char.islower():
            swapped_chars.append(char.upper())
        else:
            swapped_chars.append(char)
            
    return "".join(swapped_chars)

# Test execution
print(manual_swapcase("Python 3.10 Code!")) # Output: pYTHON 3.10 cODE!
