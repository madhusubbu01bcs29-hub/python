def validate_password(password):
    # Length Constraint
    if not (8 <= len(password) <= 15):
        return "Invalid: Length must be between 8 and 15 characters."
    
    # Space Checking
    if " " in password:
        return "Invalid: Password must not contain any spaces."
    
    # Flags for individual checks
    has_digit = False
    has_lower = False
    has_upper = False
    has_special = False
    
    special_chars = "@#%&!$" # Add any other specific characters here
    
    for char in password:
        if char.isdigit():
            has_digit = True
        elif char.islower():
            has_lower = True
        elif char.isupper():
            has_upper = True
        elif char in special_chars or not char.isalnum():
            has_special = True
            
    # Evaluation
    if not has_digit:
        return "Invalid: Missing at least one digit (0-9)."
    if not has_lower:
        return "Invalid: Missing at least one lowercase letter (a-z)."
    if not has_upper:
        return "Invalid: Missing at least one uppercase letter (A-Z)."
    if not has_special:
        return "Invalid: Missing at least one special character."
        
    return "Valid Password! Match confirmed against policies."

# Test execution
print(validate_password("SecureP@ss123"))
