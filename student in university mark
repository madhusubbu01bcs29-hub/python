import sys
import gc
class University:
    def __init__(self, university_name):
        self.university_name = university_name
        self.students = []
    class Student:
        def __init__(self, rollno, name, university):
            self.rollno = rollno
            self.name = name
            self.university = university
        def display_details(self):
            print(f"Roll No: {self.rollno}, Name: {self.name}, University: {self.university.university_name}")
        def __del__(self):
            print(f"Student '{self.name}' object is garbage collected")
    def add_student(self, rollno, name):
        student = University.Student(rollno, name, self)
        self.students.append(student)
        print(f"\nStudent '{name}' added")
        print("Reference count (student):", sys.getrefcount(student) - 1)
        print("Reference count (university):", sys.getrefcount(self) - 1)
    def remove_student(self, rollno):
        for i, student in enumerate(self.students):
            if student.rollno == rollno:
                print(f"\nRemoving student '{student.name}'")
                print("Reference count before deletion:", sys.getrefcount(student) - 1)
                removed_student = self.students.pop(i)
                del removed_student
                gc.collect()
                print("Garbage collection done")
                return
        print("Student not found")
    def display_all(self):
        print(f"\nStudents in {self.university_name}:")
        if not self.students:
            print("No students available")
        else:
            for student in self.students:
                student.display_details()
# ---------------- MAIN PROGRAM ----------------
gc.enable()
uname = input("Enter University Name: ")
u = University(uname)
n = int(input("Enter number of students: "))
for i in range(n):
    print(f"\nEnter details for student {i+1}")
    roll = int(input("Roll No: "))
    name = input("Name: ")
    u.add_student(roll, name)
u.display_all()
roll_remove = int(input("\nEnter roll number to remove: "))
u.remove_student(roll_remove)
u.display_all()
print("\nDeleting university object...")
del u
gc.collect()
print("Final garbage collection completed")
